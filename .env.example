CAPTURE_INTERVAL_SECONDS=60
SCREENSHOT_DIR=screenshots
DB_PATH=dailylens.db
MAX_SCREENSHOT_WIDTH=1280
CLAUDE_MODEL=sonnet

# Output language: ko (Korean), en (English), ja (Japanese), zh (Chinese)
LANGUAGE=ko

# Number of recent captures to include as context (0 to disable)
CONTEXT_SIZE=5

# Duplicate detection: skip if similarity >= threshold (0-100%)
DUPLICATE_THRESHOLD=95

# Comma-separated list of apps to skip (sensitive content)
SKIP_APPS=1Password,Keychain Access,SecurityAgent,loginwindow

# Comma-separated window title keywords to skip
SKIP_TITLE_KEYWORDS=password,비밀번호,암호,private,secret,credential,로그인,signin,sign in
